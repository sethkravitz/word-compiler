# Required for LLM generation features (prose generation, bootstrap, auditor subtext, voice profiling)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-key-here

# Optional: use a non-Anthropic backend (OpenRouter, etc.)
# LLM_BASE_URL=https://openrouter.ai/api
# LLM_API_KEY=your-openrouter-key-here

# Optional: override the default server port (default: 3001)
# PORT=3001
