{
  "name": "word-compiler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "npx vitest run",
    "test:watch": "vitest",
    "proxy": "tsx server/proxy.ts",
    "dev:all": "concurrently \"vite\" \"tsx server/proxy.ts\"",
    "eval": "tsx eval/runner.ts",
    "eval:quick": "tsx eval/runner.ts --rollouts=1",
    "eval:mock": "tsx eval/runner.ts --mock --rollouts=1",
    "eval:nightly": "tsx eval/runner.ts --rollouts=5",
    "eval:smoke": "tsx eval/stagehand/smoke.test.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "check-all": "biome check && tsc --noEmit && npx vitest run",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "biome check --write"
    ],
    "server/**/*.ts": [
      "biome check --write"
    ],
    "eval/**/*.ts": [
      "biome check --write"
    ],
    "tests/**/*.ts": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.75.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.14",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "svelte": "^5.53.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@browserbasehq/stagehand": "^3.0.8",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/svelte": "^10.2.10",
    "@storybook/svelte-vite": "^10.2.10",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^27.0.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "storybook": "^10.2.10",
    "svelte-codemirror-editor": "^2.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "vite": "^6.4.1"
    }
  }
}
